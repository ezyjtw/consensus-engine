FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /ledger ./cmd/ledger

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /ledger /app/ledger
ENV REDIS_ADDR="redis:6379"
ENV POSTGRES_DSN="postgres://arbsuite:arbsuite@postgres:5432/arbsuite?sslmode=disable"
ENTRYPOINT ["/app/ledger"]
