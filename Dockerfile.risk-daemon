FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /risk-daemon ./cmd/risk-daemon

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /risk-daemon /risk-daemon
COPY configs/ /configs/
ENTRYPOINT ["/risk-daemon"]
