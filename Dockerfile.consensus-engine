FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /consensus-engine ./cmd/consensus-engine

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /consensus-engine /consensus-engine
ENTRYPOINT ["/consensus-engine"]
