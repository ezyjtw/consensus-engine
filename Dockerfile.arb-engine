FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /arb-engine ./cmd/arb-opportunity-engine

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /arb-engine /arb-engine
COPY configs/ /configs/
ENTRYPOINT ["/arb-engine", "-config", "/configs/policies/arb_engine.yaml"]
