FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /funding-engine ./cmd/funding-engine

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /funding-engine /app/funding-engine
COPY configs/ /app/configs/
ENV REDIS_ADDR="redis:6379"
ENTRYPOINT ["/app/funding-engine"]
