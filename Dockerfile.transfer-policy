FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /transfer-policy ./cmd/transfer-policy

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /transfer-policy /transfer-policy
COPY configs/ /configs/
ENTRYPOINT ["/transfer-policy"]
