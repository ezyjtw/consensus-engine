FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /capital-allocator ./cmd/capital-allocator

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /capital-allocator /app/capital-allocator
COPY configs/ /app/configs/
ENV REDIS_ADDR="redis:6379"
ENTRYPOINT ["/app/capital-allocator"]
