FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /market-data ./cmd/market-data

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /market-data /market-data
COPY configs/market_data.yaml /configs/market_data.yaml
ENTRYPOINT ["/market-data", "-config", "/configs/market_data.yaml"]
